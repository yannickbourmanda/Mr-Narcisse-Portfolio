# APP_URL: The URL where this app is hosted (e.g., https://votre-domaine.com)
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Clé API pour l'envoi d'emails automatiques.
# Obtenez-la gratuitement sur : https://resend.com/
RESEND_API_KEY=""

# CONTACT_EMAIL: Email destinataire pour le formulaire de contact (Optionnel, par défaut: yannick.detougou@aun.edu.ng)
CONTACT_EMAIL=""

# SOCIAL_WEBHOOK_SECRET: Mot de passe secret pour protéger la route /api/webhooks/social
# Utile si vous utilisez Zapier ou Make.com pour publier des posts LinkedIn/Facebook vers le blog.
SOCIAL_WEBHOOK_SECRET="votre_mot_de_passe_secret"

# GOOGLE ANALYTICS (SEO)
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# CLOUDINARY CONFIGURATION (Hébergement d'images et documents)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET="portfolio_upload"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
